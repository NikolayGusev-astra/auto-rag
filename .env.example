# Embedding
RAG_EMBEDDING_URL=http://localhost:1234/v1/embeddings
RAG_EMBEDDING_MODEL=text-embedding-baai-bge-m3-568m
RAG_EMBEDDING_DIM=1024

# LM Studio
RAG_LM_STUDIO_URL=http://localhost:1234/v1/chat/completions

# LLM Classify
RAG_CLASSIFY=true
RAG_CLASSIFY_MODEL=google/gemma-4-e4b

# LLM Rewrite
RAG_REWRITE=true
RAG_REWRITE_MODEL=qwen2.5-7b-instruct

# LLM Decompose
RAG_DECOMPOSE=true
RAG_DECOMPOSE_MODEL=qwen2.5-7b-instruct

# LLM Eval
RAG_LLM_EVAL=true
RAG_LLM_EVAL_MODEL=qwen2.5-7b-instruct
RAG_LLM_VERIFY=true
RAG_LLM_VERIFY_MODEL=qwen2.5-7b-instruct

# Reranker
RAG_RERANK=true
RAG_RERANK_TOP=15
RAG_RERANK_FINAL_K=5

# DCD mode: keyword | llm | hybrid
RAG_DCD_MODE=keyword

# Local cross-encoder reranker
RAG_LOCAL_RERANKER=true
RAG_LOCAL_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L6-v2
RAG_LOCAL_RERANKER_DEVICE=cpu

# Hybrid FTS+Vector search
RAG_HYBRID_SEARCH=true
RAG_HYBRID_RECALL_TOPK=20
RAG_HYBRID_RRF_CONSTANT=60

# Web search (SearXNG)
RAG_SEARXNG_URL=http://localhost:8080
RAG_WEB_SEARCH=true
RAG_WEB_SEARCH_RESULTS=5

# MCP servers (optional)
RAG_CONFLUENCE_URL=
RAG_CONFLUENCE_TOKEN=
RAG_JIRA_URL=
RAG_JIRA_TOKEN=
RAG_LODESTONE_URL=
RAG_LODESTONE_TOKEN=
RAG_CONTEXT7_URL=https://context7.com/mcp/
RAG_PROTOPACK_URL=

# Federated RAG (optional)
RAG_FEDERATED_ENABLED=false
RAG_FEDERATED_SERVERS=
# Для каждого сервера:
RAG_FEDERATED_<NAME>_HOST=192.168.1.100
RAG_FEDERATED_<NAME>_USER=ubuntu
RAG_FEDERATED_<NAME>_PORT=22
RAG_FEDERATED_<NAME>_REMOTE_PORT=8000
RAG_FEDERATED_<NAME>_KEY=~/.ssh/id_rsa
RAG_FEDERATED_<NAME>_USE_SSH=true
# Или direct HTTP (без SSH):
# RAG_FEDERATED_<NAME>_USE_SSH=false

# ── Federated endpoint auth ──
RAG_FEDERATED_API_KEY=  # если задан — auth включён
RAG_FEDERATED_PORT=8000
RAG_FEDERATED_HOST=127.0.0.1  # 0.0.0.0 для external access

# ── Logging ──
RAG_LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR
RAG_LOG_FORMAT=%(asctime)s [%(levelname)s] %(name)s: %(message)s

# Wiki paths (через запятую)
RAG_WIKI_PATHS=~/wiki,~/llm-wiki
RAG_ZVEC_PATH=~/.cache/zvec
RAG_ZVEC_COLLECTION=wiki

# ── CPU Fallback для EmbeddingService ──
# Когда LM Studio недоступен, используется sentence-transformers
RAG_ST_FALLBACK_ENABLED=true
RAG_ST_FALLBACK_MODEL=BAAI/bge-m3
RAG_ST_FALLBACK_DEVICE=auto  # auto | cpu | cuda
RAG_ST_FALLBACK_BATCH=8  # меньше batch на CPU

# ── Embedding cache ──
RAG_EMBEDDING_CACHE=~/.cache/auto-rag/embeddings.sqlite
RAG_EMBEDDING_BATCH=32
RAG_EMBEDDING_RETRIES=2
